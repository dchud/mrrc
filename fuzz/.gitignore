# cargo-fuzz build output and crash reproducers (local-only; crashes get
# copied into tests/ as regressions).
target
artifacts
coverage

# cargo-fuzz mutator-discovered corpus additions are local-only. They use
# hash-like filenames and can grow into the GBs over a long fuzz run, so
# they must not be committed. Only curated seeds (explicitly allow-listed
# below) are tracked.
corpus/*/*
!corpus/*/.gitkeep
!corpus/parse_record/simple_book
!corpus/parse_record/music_score
!corpus/parse_record/simple_authority
!corpus/parse_record/with_control_fields
!corpus/parse_record/multi_records
!corpus/roundtrip_binary/simple_book
!corpus/roundtrip_binary/music_score
!corpus/roundtrip_binary/simple_authority
!corpus/roundtrip_binary/with_control_fields
!corpus/roundtrip_binary/multi_records
!corpus/error_classification/simple_book
!corpus/error_classification/music_score
!corpus/error_classification/simple_authority
!corpus/error_classification/with_control_fields
!corpus/error_classification/multi_records
!corpus/recovery_mode_consistency/simple_book
!corpus/recovery_mode_consistency/music_score
!corpus/recovery_mode_consistency/simple_authority
!corpus/recovery_mode_consistency/with_control_fields
!corpus/recovery_mode_consistency/multi_records
